# Staging environment variables. Same schema as .env.prod but different
# hostnames, database, Redis DB index, and CORS origin.
#
# Copy to /opt/duta-deploy/.env.staging and fill in real values.

DUTA_API_TAG=main
DUTA_WEB_TAG=main

NODE_ENV=production
PORT=3001

# Database — SEPARATE staging DB on shared Postgres instance
DATABASE_URL="postgresql://duta:CHANGE_ME@postgres:5432/duta_staging?schema=public"

# Redis — DB index 1 (prod uses default 0)
REDIS_URL="redis://redis:6379/1"

TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=CHANGE_ME

# Logto — shared instance but staging API resource/audience
LOGTO_ENDPOINT=http://logto:3001
LOGTO_PUBLIC_ENDPOINT=https://auth.duta.val.id
LOGTO_AUDIENCE=https://api-staging.duta.val.id
LOGTO_ISSUER=https://auth.duta.val.id/oidc
LOGTO_JWKS_URI=https://auth.duta.val.id/oidc/jwks

CORS_ORIGIN=https://staging.duta.val.id

# SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@enamdua.id

# Xendit (same sandbox key as prod, or separate test key)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

SENTRY_DSN=
DEEPGRAM_API_KEY=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=duta-uploads-staging
R2_PUBLIC_URL=
