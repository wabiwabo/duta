# Production environment variables for duta-api and duta-web containers.
# Copy to /opt/duta-deploy/.env.prod and fill in real values.
# NEVER commit .env.prod. This file is the shape, not the secrets.
#
# Hostnames MUST use Docker container aliases (postgres, redis, logto,
# typesense), NOT "localhost" — containers reach each other via the
# duta-api_default bridge network.

# Image tag pins (override to :sha-<short> or :v1.2.3 for reproducible prod)
DUTA_API_TAG=latest
DUTA_WEB_TAG=latest

# Runtime
NODE_ENV=production
PORT=3001

# Database (alias: postgres)
DATABASE_URL="postgresql://duta:CHANGE_ME@postgres:5432/duta?schema=public"

# Redis (alias: redis)
REDIS_URL="redis://redis:6379"

# Typesense (alias: typesense)
TYPESENSE_HOST=typesense
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=CHANGE_ME

# Logto (alias: logto — internal container port is 3001, NOT 3302 which is host-mapped)
LOGTO_ENDPOINT=http://logto:3001
LOGTO_PUBLIC_ENDPOINT=https://auth.duta.val.id
LOGTO_AUDIENCE=https://api.duta.val.id
LOGTO_ISSUER=https://auth.duta.val.id/oidc
LOGTO_JWKS_URI=https://auth.duta.val.id/oidc/jwks

# CORS (browser-visible origin)
CORS_ORIGIN=https://duta.val.id

# SMTP (AWS SES via enamdua.id)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@enamdua.id

# Xendit
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Sentry
SENTRY_DSN=

# Deepgram (podcast transcription)
DEEPGRAM_API_KEY=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cloudflare R2 (media storage — may be empty if not configured)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=duta-uploads
R2_PUBLIC_URL=
